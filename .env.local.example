# ─────────────────────────────────────────────────────────────
# DEO Conseil — Variables d'environnement pour développement local
# ─────────────────────────────────────────────────────────────
# Copiez ce fichier en ".env" (ou ".env.local") à la racine du projet
# et remplissez les valeurs manquantes.
# ─────────────────────────────────────────────────────────────

# URL du script Google Apps Script (GAS) déployé
# Obtenez-la dans Google Apps Script → Déployer → Gérer les déploiements
VITE_GAS_URL=https://script.google.com/macros/s/AKfycby0b-V18yDy5jaRGAiDiVEf7352FRCHJ9OYL2Cx4IghMs-g2g3SXBJdKTA-49k6zCEc/exec

# Cloudinary — upload d'images
VITE_CLOUDINARY_CLOUD_NAME=dywocv2it
VITE_CLOUDINARY_UPLOAD_PRESET=deo_conseil_unsigned

# Manus OAuth (nécessaire pour le Dashboard Admin)
# Ces valeurs sont spécifiques à l'environnement Manus — non disponibles en local
# Laissez vide pour désactiver l'authentification en local
VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=

# Manus Forge API (fonctionnalités IA — chatbot)
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
